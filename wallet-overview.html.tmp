  <div id="toastWrap" class="toasts"></div>

  <!-- 共享底座 -->
  <script src="_shared.js"></script>
  <script>
    SharedHeader.mount({ activeNav: "wallet" });
    // wallet-overview.html 的 wallet chip 显示当前空间钱包真实余额（而不是 ws.accountBalance）
    // SharedHeader.refresh 默认显示 accountBalance；这里覆盖一次，并在空间切换后由 onWorkspaceChanged 再次刷新
    (function () {
      function refreshWalletChipFromKv() {
        var ws = window.demoApp.getCurrentWorkspace();
        var wallets = window.demoApp.getWallets();
        var w = wallets[ws.walletKey];
        var balance = w ? w.balance : ws.accountBalance;
        var $amt = document.getElementById("walletAmount");
        var $acc = document.getElementById("walletAccount");
        if ($amt) $amt.textContent = window.fmtMoney(balance);
        if ($acc) $acc.textContent = ws.accountType;
      }
      // 暴露给页内业务代码（充值 / 划拨 / 提现完成后刷新顶栏）
      window.refreshTopbar = refreshWalletChipFromKv;
      window.renderWsDropdownGlobal = function () { /* SharedHeader 自己渲染，外部触发刷新即可 */ refreshWalletChipFromKv(); };
      window.refreshAll = window.refreshAll || function () { refreshWalletChipFromKv(); };
      // 切换空间时刷新（SharedHeader 会调用 onWorkspaceChanged）
      var prevHook = window.onWorkspaceChanged;
      window.onWorkspaceChanged = function () {
        refreshWalletChipFromKv();
        if (typeof prevHook === "function") prevHook();
      };
      refreshWalletChipFromKv();
    })();
  </script>


  <!-- 钱包业务交互 -->
  <script>
  (function () {
    const $ = (id) => document.getElementById(id);

    // 当前空间账户大卡
    function renderCurrentCard() {
      const ws = window.demoApp.getCurrentWorkspace();
      const wallets = window.demoApp.getWallets();
      const wallet = wallets[ws.walletKey];
      const card = $("currentCard");

      card.classList.remove("team-budget", "personal", "enterprise-main", "budget-missing");

      if (ws.id === "cf-ip" && ws.budgetMissing) {
        card.classList.add("budget-missing");
        $("ccWsName").textContent = ws.name;
        $("ccAccountName").textContent = "未配置团队预算账户";
        $("ccBalance").textContent = "—";
        $("ccLocked").textContent = "—";
        $("ccAllocated").textContent = "—";
        $("ccUsage").textContent = "—";
        $("ccActions").innerHTML = '<button class="cc-btn">向企业管理员申请预算</button><button class="cc-btn ghost" onclick="window.openAllocate(\'team-budget-cf-ip\')">企业管理员：现在配置</button>';
        if (!card.querySelector(".missing-tip")) {
          const tip = document.createElement("div");
          tip.className = "missing-tip";
          tip.innerHTML = "ℹ️ <strong>规则提醒</strong>：本空间未配置独立预算账户，按平台规则将自动回退至企业主账户结算。订单仍记录「由 IP 孵化组发起」，但实际扣款主体为企业主账户（¥1,250,000）。";
          card.appendChild(tip);
        }
        return;
      }
      // 移除回退提示
      const oldTip = card.querySelector(".missing-tip");
      if (oldTip) oldTip.remove();

      card.classList.add(ws.payer.type);
      $("ccWsName").textContent = ws.name;
      $("ccAccountName").textContent = wallet ? wallet.name : ws.payer.name;
      $("ccBalance").textContent = window.fmtMoney(wallet ? wallet.balance : 0);
      $("ccLocked").textContent = window.fmtMoney(wallet ? (wallet.lockedAmount || 0) : 0);

      if (wallet && wallet.allocated) {
        $("ccAllocated").textContent = window.fmtMoney(wallet.allocated);
        const usage = wallet.allocated > 0 ? Math.round((wallet.allocated - wallet.balance) / wallet.allocated * 100) : 0;
        $("ccUsage").textContent = usage + "%";
      } else {
        $("ccAllocated").textContent = "—";
        $("ccUsage").textContent = "—";
      }

      // 操作按钮
      let actions = "";
      if (ws.payer.type === "personal") {
        actions = '<button class="cc-btn" onclick="window.openRecharge(\'' + ws.walletKey + '\')">充值</button>'
          + '<button class="cc-btn ghost" onclick="window.openWithdraw(\'' + ws.walletKey + '\')">提现</button>';
      } else if (ws.payer.type === "team-budget") {
        actions = '<button class="cc-btn ghost" onclick="window.demoToast(\'团队成员可申请增加预算 →\', \'info\')">申请追加预算</button>'
          + '<button class="cc-btn ghost" onclick="window.demoToast(\'扣款记录已聚合到下方流水\', \'info\')">查看团队消费</button>';
      } else if (ws.payer.type === "enterprise-main") {
        actions = '<button class="cc-btn" onclick="window.openRecharge(\'' + ws.walletKey + '\')">企业充值</button>';
        if (ws.canAllocateBudget) {
          actions += '<button class="cc-btn ghost" onclick="window.openAllocate()">📤 划拨预算给团队</button>';
        }
      }
      $("ccActions").innerHTML = actions;
    }

    // 账户矩阵（按当前空间权限过滤展示）
    function renderAccountsGrid() {
      const ws = window.demoApp.getCurrentWorkspace();
      const wallets = window.demoApp.getWallets();

      // 全量账户清单
      const ALL = {
        "enterprise-main-cf": { wallet: wallets["enterprise-main-cf"], type: "enterprise-main", title: "骋风天合 - 企业主账户", subtitle: "由企业管理员维护", key: "enterprise-main-cf" },
        "team-budget-cf-drama": { wallet: wallets["team-budget-cf-drama"], type: "team-budget", title: "短剧制作中心 - 团队预算账户", subtitle: "归属：骋风天合·短剧制作中心", key: "team-budget-cf-drama", boundWs: "cf-drama" },
        "team-budget-cf-marketing": { wallet: wallets["team-budget-cf-marketing"], type: "team-budget", title: "市场宣传组 - 团队预算账户", subtitle: "归属：骋风天合·市场宣传组", key: "team-budget-cf-marketing", boundWs: "cf-marketing" },
        "team-budget-cf-ip": { wallet: wallets["team-budget-cf-ip"] || null, type: wallets["team-budget-cf-ip"] ? "team-budget" : "unset", title: "IP 孵化组 - 团队预算账户", subtitle: "归属：骋风天合·IP 孵化组", key: "team-budget-cf-ip", boundWs: "cf-ip", isUnset: !wallets["team-budget-cf-ip"] },
        "personal-account-lixueqin": { wallet: wallets["personal-account-lixueqin"], type: "personal", title: "昭岚 - 个人账户", subtitle: "个人空间下使用", key: "personal-account-lixueqin", boundWs: "personal" }
      };

      // 根据当前空间决定可见账户（权限隔离）
      let visibleKeys = []; // 完整可见的账户
      let limitedKeys = []; // 受限可见（只显示部分信息，如"上游来源"）
      let sectionTitle = "", sectionSub = "";

      if (ws.id === "personal") {
        // 个人空间：只看个人账户
        visibleKeys = ["personal-account-lixueqin"];
        sectionTitle = "我的账户";
        sectionSub = "个人空间下仅可见个人账户。如需企业资金请切换到对应工作空间。";
      } else if (ws.id === "cf-admin") {
        // 企业管理员：看全部
        visibleKeys = ["enterprise-main-cf", "team-budget-cf-drama", "team-budget-cf-marketing", "team-budget-cf-ip", "personal-account-lixueqin"];
        sectionTitle = "骋风天合 · 全部资金账户";
        sectionSub = "管理员视角：企业主 → 团队预算 → 个人，完整可见。";
      } else if (ws.id === "cf-drama" || ws.id === "cf-marketing" || ws.id === "cf-ip") {
        // 团队空间成员：本团队完整可见 + 企业主受限可见 + 个人账户
        visibleKeys = [ws.walletKey === "enterprise-main-cf" ? null : ws.walletKey, "personal-account-lixueqin"].filter(Boolean);
        // IP 孵化组也要展示自己的"未配置"状态
        if (ws.id === "cf-ip" && !visibleKeys.includes("team-budget-cf-ip")) visibleKeys.unshift("team-budget-cf-ip");
        // 企业主账户受限可见
        limitedKeys = ["enterprise-main-cf"];
        sectionTitle = "本团队可见账户";
        sectionSub = "团队成员视角：仅可见本团队预算 + 上级企业主账户（受限）+ 个人账户。其他团队的预算账户对你不可见。";
      }

      // 写入标题
      $("accountsSectionTitle").textContent = sectionTitle;
      $("accountsSectionSub").textContent = sectionSub;

      // 渲染卡片
      const renderCard = (item, mode) => {
        const isCurrent = ws.walletKey === item.key;
        const cls = "account-card" + (isCurrent ? " current" : "") + (mode === "limited" ? " limited" : "");
        let typeLabel = item.type === "personal" ? "个人账户" : item.type === "team-budget" ? "团队预算账户" : item.type === "enterprise-main" ? "企业主账户" : "未配置";
        let actions = "";

        if (mode === "limited") {
          // 受限视图：团队成员看企业主
          const allocatedToTeam = wallets[ws.walletKey] && wallets[ws.walletKey].allocated;
          return '<div class="' + cls + '">'
            + '<div class="ac-head"><div><div class="ac-title">' + item.title + '</div><div style="font-size:11px;color:#8c8c8c;margin-top:2px">上游账户 · 受限可见</div></div><span class="ac-type ' + item.type + '">企业主账户</span></div>'
            + '<div class="ac-balance" style="font-size:18px;color:#bfbfbf">¥ ****</div>'
            + '<div class="ac-meta"><span>已划拨给本团队</span><span class="ac-meta-val">' + window.fmtMoney(allocatedToTeam || 0) + '</span></div>'
            + '<div class="ac-meta"><span>权限说明</span><span class="ac-meta-val" style="color:#8c8c8c;font-size:11px">仅企业管理员可见完整余额</span></div>'
            + '<div class="ac-actions"><button onclick="window.demoToast(\'你不是企业管理员，无权操作企业主账户\', \'warn\')" disabled style="cursor:not-allowed;color:#bfbfbf">充值</button><button onclick="window.demoToast(\'追加预算需联系企业管理员\', \'info\')">申请追加预算</button></div>'
            + '</div>';
        }

        if (item.isUnset) {
          actions = '<button class="warn" onclick="window.openAllocate(\'' + item.key + '\')">企业管理员：配置预算</button>';
        } else if (item.type === "personal") {
          actions = '<button class="primary" onclick="window.openRecharge(\'' + item.key + '\')">充值</button><button onclick="window.openWithdraw(\'' + item.key + '\')">提现</button>';
        } else if (item.type === "team-budget") {
          if (ws.id === "cf-admin") {
            actions = '<button onclick="window.demoToast(\'切换到该团队空间查看详情\', \'info\'); setTimeout(() => { window.demoApp.setCurrentWorkspace(\'' + item.boundWs + '\'); window.refreshAll(); window.renderWsDropdownGlobal(); }, 500)">切到该空间</button><button onclick="window.demoToast(\'团队预算调整需企业管理员操作\', \'warn\')">调整预算</button>';
          } else {
            actions = '<button onclick="window.demoToast(\'团队预算追加需联系企业管理员\', \'info\')">申请追加预算</button><button onclick="window.demoToast(\'查看本团队消费明细\', \'info\')">查看消费</button>';
          }
        } else if (item.type === "enterprise-main") {
          actions = '<button class="primary" onclick="window.openRecharge(\'' + item.key + '\')">企业充值</button><button onclick="window.openAllocate()">划拨给团队</button>';
        }

        const balanceHtml = item.isUnset
          ? '<div class="ac-balance unset">未配置</div>'
          : '<div class="ac-balance">' + window.fmtMoney(item.wallet.balance) + '</div>';
        const meta = item.isUnset
          ? '<div class="ac-meta"><span>说明</span><span class="ac-meta-val" style="color:#cf1322">下单将回退至企业主账户</span></div>'
          : '<div class="ac-meta"><span>已锁定</span><span class="ac-meta-val">' + window.fmtMoney(item.wallet.lockedAmount || 0) + '</span></div>'
            + (item.wallet.allocated ? '<div class="ac-meta"><span>总预算</span><span class="ac-meta-val">' + window.fmtMoney(item.wallet.allocated) + '</span></div>' : '');

        return '<div class="' + cls + '">'
          + '<div class="ac-head"><div><div class="ac-title">' + item.title + (isCurrent ? ' <span style="color:#1890ff;font-size:11px">· 当前</span>' : '') + '</div>' + (item.subtitle ? '<div style="font-size:11px;color:#8c8c8c;margin-top:2px">' + item.subtitle + '</div>' : '') + '</div><span class="ac-type ' + item.type + '">' + typeLabel + '</span></div>'
          + balanceHtml
          + meta
          + '<div class="ac-actions">' + actions + '</div>'
          + '</div>';
      };

      const visible = visibleKeys.map(k => ALL[k]).filter(Boolean);
      const limited = limitedKeys.map(k => ALL[k]).filter(Boolean);
      const html = visible.map(it => renderCard(it, "full")).join("") + limited.map(it => renderCard(it, "limited")).join("");
      $("accountsGrid").innerHTML = html;
    }

    // 团队预算使用率（个人空间隐藏；团队成员只看本团队；管理员看全部）
    function renderBudgetUsage() {
      const ws = window.demoApp.getCurrentWorkspace();
      const wrap = document.getElementById("budgetUsageWrap");
      if (!wrap) return;

      // 个人空间：隐藏整个 section
      if (ws.id === "personal") { wrap.style.display = "none"; return; }
      wrap.style.display = "";

      const ALL_TEAMS = [
        { key: "team-budget-cf-drama", name: "短剧制作中心", icon: "🎬", boundWs: "cf-drama" },
        { key: "team-budget-cf-marketing", name: "市场宣传组", icon: "📢", boundWs: "cf-marketing" },
        { key: "team-budget-cf-ip", name: "IP 孵化组", icon: "💎", boundWs: "cf-ip" }
      ];
      let teams;
      if (ws.id === "cf-admin") {
        teams = ALL_TEAMS;
        document.getElementById("budgetSectionTitle").textContent = "团队预算使用率";
        document.getElementById("budgetCardTitle").textContent = "各团队预算分配与使用情况";
        document.getElementById("budgetCardSub").textContent = "管理员视角：可见全部团队预算分配。";
      } else {
        // 团队成员：只看本团队
        teams = ALL_TEAMS.filter(t => t.boundWs === ws.id);
        document.getElementById("budgetSectionTitle").textContent = "本团队预算使用率";
        document.getElementById("budgetCardTitle").textContent = "本团队预算分配与使用情况";
        document.getElementById("budgetCardSub").textContent = "团队成员仅可见本团队预算情况，其他团队的预算对你不可见。";
      }

      const wallets = window.demoApp.getWallets();
      const html = teams.map(t => {
        const w = wallets[t.key];
        if (!w || !w.allocated) {
          return '<div class="budget-row">'
            + '<div class="bu-name">' + t.icon + ' ' + t.name + '<div class="bu-tag" style="color:#cf1322">未配置预算</div></div>'
            + '<div class="bu-bar"><div class="bu-segment-spent" style="width:0;background:#f5f5f5"></div></div>'
            + '<div class="bu-stat" style="color:#8c8c8c">未配置 · <a href="#" onclick="event.preventDefault(); window.openAllocate(\'' + t.key + '\')" style="color:#1890ff">立即配置</a></div>'
            + '</div>';
        }
        const allocated = w.allocated;
        const balance = w.balance;
        const locked = w.lockedAmount || 0;
        const spent = Math.max(0, allocated - balance - locked);
        const spentPct = (spent / allocated * 100).toFixed(1);
        const lockedPct = (locked / allocated * 100).toFixed(1);
        const totalUsedPct = ((spent + locked) / allocated * 100).toFixed(1);
        return '<div class="budget-row">'
          + '<div class="bu-name">' + t.icon + ' ' + t.name + '<div class="bu-tag">总预算 ' + window.fmtMoney(allocated) + '</div></div>'
          + '<div class="bu-bar">'
            + '<div class="bu-segment-spent" style="width:' + spentPct + '%" title="已结算 ' + window.fmtMoney(spent) + '"></div>'
            + '<div class="bu-segment-locked" style="width:' + lockedPct + '%" title="已锁定 ' + window.fmtMoney(locked) + '"></div>'
          + '</div>'
          + '<div class="bu-stat">'
            + '已用 <span class="bu-stat-val">' + window.fmtMoney(spent + locked) + '</span> / ' + window.fmtMoney(allocated)
            + '<div style="font-size:11px;color:#8c8c8c;margin-top:2px">使用率 ' + totalUsedPct + '%（结算 ' + spentPct + '% + 锁定 ' + lockedPct + '%）</div>'
          + '</div>'
          + '</div>';
      }).join("");
      const el = document.getElementById("budgetRows");
      if (el) el.innerHTML = html;
    }

    // KPI 动态化（按当前空间）
    function renderKPIs() {
      const ws = window.demoApp.getCurrentWorkspace();
      const wallets = window.demoApp.getWallets();
      const row = document.getElementById("kpiRow");
      const bar = document.getElementById("pendingBar");
      if (!row || !bar) return;

      let kpis = [];
      let pendings = [];

      if (ws.id === "personal") {
        // 个人空间：个人维度
        const w = wallets["personal-account-lixueqin"];
        kpis = [
          { icon: "💳", label: "个人累计充值（年初至今）", value: "¥4,200", trend: "本月充值 <strong>¥1,000</strong>", cls: "" },
          { icon: "📤", label: "个人累计支出（年初至今）", value: "¥1,800", trend: "本月支出 <strong>¥800</strong> · <span class=\"delta-up\">↑ 16%</span>", cls: "orange" },
          { icon: "🔒", label: "已锁定", value: window.fmtMoney(w ? (w.lockedAmount || 0) : 0), trend: "无进行中订单", cls: "green" },
          { icon: "💰", label: "当前可用余额", value: window.fmtMoney(w ? w.balance : 0), trend: "建议保持 ¥3,000+ 以接受小额下单", cls: "purple" }
        ];
        pendings = [
          { num: "0", text: "笔提现待审核", cls: "" },
          { num: "1", text: "条新通知（来自骋风天合）", cls: "warn" },
          { num: "2", text: "项个人协议待确认", cls: "" }
        ];
      } else if (ws.id === "cf-admin") {
        // 企业管理员：全企业
        const accounts = ["personal-account-lixueqin", "team-budget-cf-drama", "team-budget-cf-marketing", "enterprise-main-cf"];
        let totalAvailable = 0, totalLocked = 0;
        accounts.forEach(k => { const w = wallets[k]; if (w) { totalAvailable += w.balance; totalLocked += (w.lockedAmount || 0); } });
        kpis = [
          { icon: "💳", label: "企业累计充值（年初至今）", value: "¥1,750,000", trend: "本月充值 <strong>¥120,000</strong> · <span class=\"delta-up\">↑ 18% vs 上月</span>", cls: "" },
          { icon: "📤", label: "企业累计支出（年初至今）", value: "¥328,500", trend: "本月支出 <strong>¥48,000</strong> · <span class=\"delta-up\">↑ 22% vs 上月</span>", cls: "orange" },
          { icon: "🔒", label: "全企业已锁定", value: window.fmtMoney(totalLocked), trend: "分布在 <strong>2 个团队</strong>·<strong>3 笔订单</strong>", cls: "green" },
          { icon: "📥", label: "全企业可用余额", value: window.fmtMoney(totalAvailable), trend: "企业主 + 各团队 + 个人合计", cls: "purple" }
        ];
        pendings = [
          { num: "1", text: "笔对公转账待财务审核", cls: "warn" },
          { num: "0", text: "笔提现待审核", cls: "" },
          { num: "3", text: "笔订单可开票", cls: "warn" },
          { num: "1", text: "个团队未配置预算", cls: "danger" },
          { num: "27%", text: "本季度团队预算使用率", cls: "" }
        ];
      } else {
        // 团队空间成员（cf-drama / cf-marketing / cf-ip）
        const w = wallets[ws.walletKey];
        const teamName = ws.shortName.replace("骋风天合·", "");
        if (ws.budgetMissing) {
          // IP 孵化组未配置预算的特殊视图
          kpis = [
            { icon: "💎", label: teamName + " 预算状态", value: "未配置", trend: "下单将回退至企业主账户结算", cls: "orange" },
            { icon: "📤", label: teamName + " 本季度支出", value: "¥0", trend: "暂无独立预算账户", cls: "" },
            { icon: "🔒", label: teamName + " 已锁定", value: "¥0", trend: "无进行中订单", cls: "green" },
            { icon: "👥", label: "团队成员", value: "8 人", trend: "包含 1 主理人 + 7 创作者", cls: "purple" }
          ];
          pendings = [
            { num: "1", text: "项：申请配置团队预算账户", cls: "danger" },
            { num: "0", text: "笔订单进行中", cls: "" },
            { num: "0", text: "笔订单可开票", cls: "" }
          ];
        } else {
          const allocated = w ? (w.allocated || 0) : 0;
          const balance = w ? w.balance : 0;
          const locked = w ? (w.lockedAmount || 0) : 0;
          const spent = Math.max(0, allocated - balance - locked);
          kpis = [
            { icon: "🎯", label: teamName + " · 本季度总预算", value: window.fmtMoney(allocated), trend: "由企业管理员划拨", cls: "" },
            { icon: "📤", label: "已结算（实际花掉）", value: window.fmtMoney(spent), trend: "占预算 <strong>" + (allocated > 0 ? (spent / allocated * 100).toFixed(1) : 0) + "%</strong>", cls: "orange" },
            { icon: "🔒", label: "已锁定（订单中）", value: window.fmtMoney(locked), trend: "占预算 <strong>" + (allocated > 0 ? (locked / allocated * 100).toFixed(1) : 0) + "%</strong>", cls: "green" },
            { icon: "💰", label: "当前可用", value: window.fmtMoney(balance), trend: "占预算 <strong>" + (allocated > 0 ? (balance / allocated * 100).toFixed(1) : 0) + "%</strong>", cls: "purple" }
          ];
          pendings = [
            { num: ws.id === "cf-drama" ? "2" : "1", text: "笔订单进行中", cls: "" },
            { num: ws.id === "cf-drama" ? "1" : "0", text: "笔需求待选承制方", cls: "warn" },
            { num: "0", text: "笔订单可开票", cls: "" },
            { num: ws.id === "cf-drama" ? "23%" : "11%", text: "本季度本团队预算使用率", cls: "" }
          ];
        }
      }

      row.innerHTML = kpis.map(k => '<div class="kpi-card ' + k.cls + '">'
        + '<div class="kpi-label"><span class="kpi-icon">' + k.icon + '</span> ' + k.label + '</div>'
        + '<div class="kpi-value">' + k.value + '</div>'
        + '<div class="kpi-trend">' + k.trend + '</div>'
        + '</div>').join("");

      bar.innerHTML = '<span class="pb-label">📌 待处理事项</span>' + pendings.map(p =>
        '<div class="pb-item ' + p.cls + '" onclick="window.demoToast(\'' + p.text + '\', \'info\')">'
          + '<span class="pb-num">' + p.num + '</span><span class="pb-text">' + p.text + '</span>'
        + '</div>'
      ).join("");
    }

    // 流水
    const TYPE_CONFIG = {
      "recharge": { icon: "💳", label: "充值", className: "recharge" },
      "lock": { icon: "🔒", label: "锁定", className: "lock" },
      "allocate": { icon: "📤", label: "划拨", className: "allocate" },
      "settle": { icon: "✅", label: "结算", className: "settle" },
      "refund": { icon: "↩️", label: "退款", className: "refund" },
      "withdraw": { icon: "💸", label: "提现", className: "refund" },
      "invoice": { icon: "🧾", label: "开票", className: "allocate" }
    };
    let flowAccount = "all", flowType = "all";
    function renderFlows() {
      let flows = window.demoApp.getFlows();
      if (flowAccount !== "all") flows = flows.filter(f => f.account === flowAccount);
      if (flowType !== "all") flows = flows.filter(f => f.type === flowType);
      $("flowCount").textContent = flows.length;
      const wallets = window.demoApp.getWallets();
      const html = flows.map(f => {
        const cfg = TYPE_CONFIG[f.type] || { icon: "•", label: f.type, className: "" };
        const accountName = wallets[f.account] ? wallets[f.account].name : f.account;
        const amtCls = f.type === "lock" ? "lock" : f.amount > 0 ? "in" : f.amount < 0 ? "out" : "";
        const amtDisplay = f.amount === 0 ? (f.lockedNote || "—") : (f.amount > 0 ? "+" : "") + window.fmtMoney(f.amount);
        return '<div class="flow-row">'
          + '<div class="flow-icon">' + cfg.icon + '</div>'
          + '<div><span class="flow-type-pill ' + cfg.className + '">' + cfg.label + '</span><div style="font-size:11px;color:#8c8c8c;margin-top:3px">' + f.time + '</div></div>'
          + '<div style="font-size:13px">' + f.desc + '</div>'
          + '<div style="font-size:12px;color:#595959">' + accountName + '</div>'
          + '<div class="flow-amt ' + amtCls + '" style="' + (f.amount === 0 ? "color:#8c8c8c;font-size:11px" : "") + '">' + amtDisplay + '</div>'
          + '<div style="font-size:12px;color:#8c8c8c">' + f.operator + '</div>'
          + '</div>';
      }).join("") || '<div style="padding:40px;text-align:center;color:#8c8c8c">暂无流水记录</div>';
      $("flowList").innerHTML = html;
    }
    $("flowAccountFilter").addEventListener("change", e => { flowAccount = e.target.value; renderFlows(); });
    $("flowTypeFilter").addEventListener("change", e => { flowType = e.target.value; renderFlows(); });

    // ============================================================
    // 充值 modal
    // ============================================================
    let rechargeWalletKey = null;
    window.openRecharge = function (walletKey) {
      rechargeWalletKey = walletKey;
      const wallets = window.demoApp.getWallets();
      const wallet = wallets[walletKey];
      $("rechargeAccountName").textContent = wallet.name;
      $("rechargeTargetName").textContent = wallet.name;
      $("rechargeCurrentBalance").textContent = window.fmtMoney(wallet.balance);
      $("rechargeAmount").value = "";
      updateRechargePreview();
      $("rechargeModal").classList.add("open");
    };
    function updateRechargePreview() {
      const wallets = window.demoApp.getWallets();
      const wallet = wallets[rechargeWalletKey];
      if (!wallet) return;
      const amt = Number($("rechargeAmount").value) || 0;
      $("rechargeAmtPreview").textContent = "+" + window.fmtMoney(amt);
      $("rechargeAfterBalance").textContent = window.fmtMoney(wallet.balance + amt);
    }
    $("rechargeAmount").addEventListener("input", updateRechargePreview);
    document.querySelectorAll("#rechargeModal .quick-amt button").forEach(btn => {
      btn.addEventListener("click", () => { $("rechargeAmount").value = btn.getAttribute("data-amt"); updateRechargePreview(); });
    });
    $("rechargeConfirmBtn").addEventListener("click", () => {
      const amt = Number($("rechargeAmount").value);
      if (!amt || amt < 100) { window.demoToast("请输入有效金额（最低 ¥100）", "err"); return; }
      const method = $("rechargeMethod").value;
      const wallets = window.demoApp.getWallets();
      if (method === "bank-transfer") {
        // 对公转账：需财务审核，余额不立即变
        window.demoApp.addFlow({ id: "F-" + Date.now(), time: now(), type: "recharge", desc: "对公转账充值（待审核 - " + window.fmtMoney(amt) + "）", account: rechargeWalletKey, amount: 0, operator: "昭岚" });
        window.demoToast("✅ 对公转账凭证已提交，财务审核中（约 1 个工作日到账）", "info");
        $("rechargeModal").classList.remove("open");
        // 模拟 3 秒后审核通过
        setTimeout(() => {
          const ws = window.demoApp.getWallets();
          ws[rechargeWalletKey].balance += amt;
          window.demoApp.setWallets(ws);
          window.demoApp.addFlow({ id: "F-" + Date.now(), time: now(), type: "recharge", desc: "对公转账充值（财务审核通过）", account: rechargeWalletKey, amount: amt, operator: "财务" });
          window.demoToast("💰 对公转账已审核通过，余额到账 " + window.fmtMoney(amt), "ok");
          window.refreshAll();
        }, 3000);
      } else {
        wallets[rechargeWalletKey].balance += amt;
        window.demoApp.setWallets(wallets);
        const methodLabel = { "online-alipay": "支付宝", "online-wechat": "微信", "online-unionpay": "银联" }[method] || "在线";
        window.demoApp.addFlow({ id: "F-" + Date.now(), time: now(), type: "recharge", desc: methodLabel + "充值", account: rechargeWalletKey, amount: amt, operator: "昭岚" });
        window.demoToast("✅ 充值成功 " + window.fmtMoney(amt), "ok");
        $("rechargeModal").classList.remove("open");
        window.refreshAll();
      }
    });

    // ============================================================
    // 划拨预算 modal
    // ============================================================
    window.openAllocate = function (presetTarget) {
      if (presetTarget) $("allocateTarget").value = presetTarget;
      $("allocateAmount").value = "";
      updateAllocPreview();
      $("allocateModal").classList.add("open");
    };
    function updateAllocPreview() {
      const wallets = window.demoApp.getWallets();
      const fromBal = wallets["enterprise-main-cf"].balance;
      const toKey = $("allocateTarget").value;
      const toWallet = wallets[toKey];
      const toBal = toWallet ? toWallet.balance : 0;
      const amt = Number($("allocateAmount").value) || 0;
      $("allocFromBalance").textContent = window.fmtMoney(fromBal);
      $("allocFromAfter").textContent = window.fmtMoney(fromBal - amt);
      $("allocToBalance").textContent = toWallet ? window.fmtMoney(toBal) : "（暂未开通）";
      $("allocToAfter").textContent = window.fmtMoney(toBal + amt);
      $("allocAmtPreview").textContent = "−" + window.fmtMoney(amt);
    }
    $("allocateAmount").addEventListener("input", updateAllocPreview);
    $("allocateTarget").addEventListener("change", updateAllocPreview);
    document.querySelectorAll("#allocateModal .quick-amt button").forEach(btn => {
      btn.addEventListener("click", () => { $("allocateAmount").value = btn.getAttribute("data-amt"); updateAllocPreview(); });
    });
    $("allocConfirmBtn").addEventListener("click", () => {
      const amt = Number($("allocateAmount").value);
      if (!amt || amt < 1000) { window.demoToast("划拨金额需 ≥ ¥1,000", "err"); return; }
      const wallets = window.demoApp.getWallets();
      const fromBal = wallets["enterprise-main-cf"].balance;
      if (amt > fromBal) { window.demoToast("企业主账户余额不足", "err"); return; }
      const toKey = $("allocateTarget").value;
      const teamMap = { "team-budget-cf-drama": { ws: "cf-drama", teamName: "短剧制作中心" }, "team-budget-cf-marketing": { ws: "cf-marketing", teamName: "市场宣传组" }, "team-budget-cf-ip": { ws: "cf-ip", teamName: "IP 孵化组" } };
      const team = teamMap[toKey];
      if (!wallets[toKey]) {
        wallets[toKey] = { type: "team-budget", name: team.teamName + " - 团队预算账户", balance: 0, lockedAmount: 0, allocated: 0, owner: team.ws };
        // 同时把工作空间的 walletKey/budgetMissing 在 LocalStorage 里没有更新（运行时 WORKSPACES 是 const，但这页的 walletKey 也指向 enterprise-main，只能下次刷新生效）
      }
      wallets["enterprise-main-cf"].balance -= amt;
      wallets[toKey].balance += amt;
      wallets[toKey].allocated = (wallets[toKey].allocated || 0) + amt;
      window.demoApp.setWallets(wallets);
      window.demoApp.addFlow({ id: "F-" + Date.now() + "a", time: now(), type: "allocate", desc: "从企业主账户划拨至 " + team.teamName, account: "enterprise-main-cf", amount: -amt, operator: "昭岚（企业管理员）" });
      window.demoApp.addFlow({ id: "F-" + Date.now() + "b", time: now(), type: "allocate", desc: "企业管理员划拨预算 → " + team.teamName, account: toKey, amount: amt, operator: "昭岚（企业管理员）" });
      window.demoToast("✅ 已划拨 " + window.fmtMoney(amt) + " 至 " + team.teamName, "ok");
      $("allocateModal").classList.remove("open");
      window.refreshAll();
      if (toKey === "team-budget-cf-ip") setTimeout(() => window.demoToast("提示：IP 孵化组已开通预算账户，下次该空间下单不再回退至企业主账户", "info"), 800);
    });

    // ============================================================
    // 提现 modal
    // ============================================================
    let withdrawWalletKey = null;
    window.openWithdraw = function (walletKey) {
      withdrawWalletKey = walletKey;
      const wallets = window.demoApp.getWallets();
      const wallet = wallets[walletKey];
      $("withdrawAccountName").textContent = wallet.name;
      $("withdrawableAmount").textContent = window.fmtMoney(wallet.balance);
      $("withdrawAmount").value = "";
      $("withdrawModal").classList.add("open");
    };
    $("withdrawConfirmBtn").addEventListener("click", () => {
      const amt = Number($("withdrawAmount").value);
      const wallets = window.demoApp.getWallets();
      const wallet = wallets[withdrawWalletKey];
      if (!amt || amt < 1) { window.demoToast("请输入有效金额", "err"); return; }
      if (amt > wallet.balance) { window.demoToast("超过可提现金额", "err"); return; }
      window.demoToast("✅ 提现申请已提交，财务审核中（1-3 个工作日到账）", "info");
      $("withdrawModal").classList.remove("open");
    });

    function now() {
      const t = new Date();
      return t.getFullYear() + "-" + pad(t.getMonth() + 1) + "-" + pad(t.getDate()) + " " + pad(t.getHours()) + ":" + pad(t.getMinutes());
    }
    function pad(n) { return String(n).padStart(2, "0"); }

    window.refreshAll = function () {
      window.refreshTopbar();
      renderCurrentCard();
      renderAccountsGrid();
      renderBudgetUsage();
      renderKPIs();
      renderFlows();
    };
    window.onWorkspaceChanged = window.refreshAll;

    renderCurrentCard();
    renderAccountsGrid();
    renderBudgetUsage();
    renderKPIs();
    renderFlows();
  })();
  </script>
</body>
</html>
