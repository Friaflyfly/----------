      <!-- 当前空间绑定账户 -->
      <div class="section-head">当前空间绑定账户 <span class="section-sub">切换顶部空间，下方卡片实时变化</span></div>
      <div class="current-card team-budget" id="currentCard">
        <div class="cc-label">当前工作空间：<span id="ccWsName">骋风天合 · 短剧制作中心</span></div>
        <div class="cc-name" id="ccAccountName">短剧制作中心 - 团队预算账户</div>
        <div class="cc-balance" id="ccBalance">¥185,000</div>
        <div class="cc-meta">
          <div class="cc-meta-item"><div class="cc-meta-label">已锁定（订单中）</div><div class="cc-meta-value" id="ccLocked">¥28,000</div></div>
          <div class="cc-meta-item"><div class="cc-meta-label">总预算</div><div class="cc-meta-value" id="ccAllocated">¥200,000</div></div>
          <div class="cc-meta-item"><div class="cc-meta-label">使用率</div><div class="cc-meta-value" id="ccUsage">8%</div></div>
        </div>
        <div class="cc-actions" id="ccActions"></div>
      </div>

      <!-- 账户矩阵（按当前空间权限过滤） -->
      <div class="section-head" id="accountsSection">
        <span id="accountsSectionTitle">骋风天合 · 全部资金账户</span>
        <span class="section-sub" id="accountsSectionSub">企业主账户 → 团队预算账户 → 个人账户</span>
      </div>
      <div class="accounts-grid" id="accountsGrid"></div>

      <!-- 团队预算使用率（仅团队空间 + 管理员视角可见） -->
