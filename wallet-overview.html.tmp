            <button data-amt="50000">¥5万</button>
            <button data-amt="100000">¥10万</button>
            <button data-amt="200000">¥20万</button>
          </div>
        </div>
        <div class="summary-box">
          <div class="sb-row"><span class="sb-label">企业主账户当前余额</span><span class="sb-val" id="allocFromBalance">¥1,250,000</span></div>
          <div class="sb-row"><span class="sb-label">划拨金额</span><span class="sb-val" id="allocAmtPreview" style="color:#cf1322">−¥0</span></div>
          <div class="sb-row"><span class="sb-label">企业主账户划拨后</span><span class="sb-val" id="allocFromAfter">¥1,250,000</span></div>
          <div class="sb-arrow">↓</div>
          <div class="sb-row"><span class="sb-label">目标账户当前余额</span><span class="sb-val" id="allocToBalance">¥185,000</span></div>
          <div class="sb-row"><span class="sb-label">划拨后</span><span class="sb-val" id="allocToAfter" style="color:#389e0d;font-size:16px">¥185,000</span></div>
        </div>
