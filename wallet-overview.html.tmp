              <option value="all">所有类型</option>
              <option value="recharge">充值</option>
              <option value="lock">锁定</option>
              <option value="allocate">划拨</option>
              <option value="settle">结算</option>
              <option value="refund">退款</option>
              <option value="withdraw">提现</option>
              <option value="invoice">开票</option>
            </select>
          </div>
        </div>
        <div class="flow-row head">
          <div></div>
          <div>类型 / 时间</div>
          <div>说明</div>
          <div>关联账户</div>
          <div>金额</div>
          <div>操作人</div>
        </div>
        <div id="flowList"></div>
      </section>
