  <!-- 充值 modal -->
  <div class="modal-mask" id="rechargeModal">
    <div class="modal">
      <div class="modal-head">
        <h3>💳 账户充值</h3>
        <p id="rechargeAccountName">骋风天合 - 企业主账户</p>
      </div>
      <div class="modal-body">
        <div class="info-tip" id="rechargeInfoTip">
          在线充值实时到账；对公转账需上传凭证后由财务审核（约 1 个工作日）。
        </div>
        <div class="form-field">
          <label>充值金额（元）</label>
          <input type="number" id="rechargeAmount" placeholder="请输入金额" min="100">
          <div class="quick-amt">
            <button data-amt="1000">¥1,000</button>
            <button data-amt="5000">¥5,000</button>
            <button data-amt="20000">¥2万</button>
            <button data-amt="50000">¥5万</button>
            <button data-amt="100000">¥10万</button>
          </div>
        </div>
        <div class="form-field">
          <label>充值方式</label>
          <select id="rechargeMethod">
            <option value="online-alipay">支付宝（实时到账）</option>
            <option value="online-wechat">微信支付（实时到账）</option>
            <option value="online-unionpay">银联（实时到账）</option>
            <option value="bank-transfer">对公转账（财务审核）</option>
          </select>
        </div>
        <div class="summary-box">
          <div class="sb-row"><span class="sb-label">充值至账户</span><span class="sb-val" id="rechargeTargetName">企业主账户</span></div>
          <div class="sb-row"><span class="sb-label">当前余额</span><span class="sb-val" id="rechargeCurrentBalance">¥0</span></div>
          <div class="sb-row"><span class="sb-label">充值金额</span><span class="sb-val" id="rechargeAmtPreview" style="color:#389e0d">+¥0</span></div>
          <div class="sb-row" style="border-top:1px solid #e8e8e8;padding-top:8px;margin-top:4px"><span class="sb-label">到账后余额</span><span class="sb-val" id="rechargeAfterBalance" style="color:#389e0d;font-size:16px">¥0</span></div>
        </div>
      </div>
      <div class="modal-foot">
        <button class="btn" onclick="document.getElementById('rechargeModal').classList.remove('open')">取消</button>
        <button class="btn primary" id="rechargeConfirmBtn">确认充值</button>
      </div>
    </div>
