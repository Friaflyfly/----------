<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>钱包与结算 - 骋风天合 · 创作门户交易平台</title>
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif; background: #f5f5f5; color: #262626; }

    /* 顶部全局栏 */
    .topbar { position: fixed; top: 0; left: 0; right: 0; height: 56px; background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.06); z-index: 200; display: flex; align-items: center; padding: 0 20px; gap: 16px; }
    .topbar .brand { display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 16px; color: #1890ff; text-decoration: none; min-width: 220px; }
    .topbar .brand-sub { color: #8c8c8c; font-weight: 400; font-size: 12px; margin-left: 4px; }
    .ws-switcher { position: relative; }
    .ws-trigger { display: flex; align-items: center; gap: 8px; padding: 6px 12px; border: 1px solid #e8e8e8; border-radius: 6px; background: #fafafa; cursor: pointer; font-size: 13px; min-width: 240px; }
    .ws-trigger:hover { border-color: #1890ff; background: #e6f7ff; }
    .ws-trigger .ws-name { font-weight: 500; color: #262626; flex: 1; }
    .ws-trigger .ws-arrow { color: #8c8c8c; font-size: 10px; }
    .ws-dropdown { display: none; position: absolute; top: calc(100% + 6px); left: 0; min-width: 320px; background: #fff; border: 1px solid #e8e8e8; border-radius: 8px; box-shadow: 0 6px 16px rgba(0,0,0,.12); padding: 8px; z-index: 300; }
    .ws-dropdown.open { display: block; }
    .ws-group-label { font-size: 12px; color: #8c8c8c; padding: 6px 10px; }
    .ws-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .ws-item:hover { background: #f0f7ff; }
    .ws-item.active { background: #e6f7ff; }
    .ws-item .ws-item-icon { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ws-item .ws-item-icon.personal { background: #fff7e6; color: #fa8c16; }
    .ws-item .ws-item-icon.team { background: #e6f7ff; color: #1890ff; }
    .ws-item .ws-item-icon.admin { background: #f9f0ff; color: #722ed1; }
    .ws-item .ws-item-main { flex: 1; min-width: 0; }
    .ws-item .ws-item-name { font-weight: 500; color: #262626; }
    .ws-item .ws-item-desc { font-size: 12px; color: #8c8c8c; margin-top: 2px; }
    .ws-item .ws-item-check { color: #1890ff; font-size: 14px; }
    .identity-switch { display: flex; gap: 4px; background: #f0f0f0; border-radius: 18px; padding: 3px; }
    .identity-switch button { border: none; background: transparent; padding: 5px 14px; border-radius: 16px; font-size: 13px; color: #595959; cursor: pointer; }
    .identity-switch button.active { background: #fff; color: #1890ff; box-shadow: 0 1px 2px rgba(0,0,0,.06); font-weight: 500; }
    .wallet-chip { display: flex; align-items: center; gap: 8px; padding: 6px 14px; background: linear-gradient(135deg, #fff7e6, #fff1d6); border: 1px solid #ffd591; border-radius: 18px; cursor: pointer; font-size: 13px; color: #d46b08; text-decoration: none; }
    .wallet-chip:hover { border-color: #fa8c16; }
    .wallet-chip .wallet-amount { font-weight: 600; font-size: 14px; }
    .wallet-chip .wallet-account { font-size: 11px; opacity: .85; }
    .avatar-wrap { position: relative; margin-left: auto; }
    .avatar-trigger { display: flex; align-items: center; gap: 8px; cursor: pointer; padding: 4px 8px; border-radius: 18px; }
    .avatar-trigger:hover { background: #f5f5f5; }
    .avatar-trigger img { width: 32px; height: 32px; border-radius: 50%; border: 1px solid #f0f0f0; }
    .avatar-trigger .avatar-name { font-size: 13px; color: #262626; }
    .avatar-dropdown { display: none; position: absolute; top: calc(100% + 6px); right: 0; min-width: 220px; background: #fff; border: 1px solid #e8e8e8; border-radius: 8px; box-shadow: 0 6px 16px rgba(0,0,0,.12); padding: 8px; z-index: 300; }
    .avatar-dropdown.open { display: block; }
    .avatar-dropdown a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 6px; color: #262626; text-decoration: none; font-size: 13px; }
    .avatar-dropdown a:hover { background: #f0f7ff; color: #1890ff; }
    .avatar-dropdown .divider { height: 1px; background: #f0f0f0; margin: 6px 4px; }

    /* 布局 */
    .app { display: flex; padding-top: 56px; min-height: 100vh; }
    .sidebar { width: 200px; background: #fff; box-shadow: 2px 0 8px rgba(0,0,0,.06); position: fixed; top: 56px; left: 0; bottom: 0; padding: 16px 0; overflow-y: auto; }
    .menu a { display: flex; align-items: center; gap: 10px; padding: 11px 24px; color: #262626; text-decoration: none; border-left: 3px solid transparent; font-size: 14px; }
    .menu a:hover { background: #f0f7ff; color: #1890ff; }
    .menu a.active { background: #e6f7ff; color: #1890ff; border-left-color: #1890ff; font-weight: 500; }
    .menu-icon { width: 18px; text-align: center; }
    .menu-group { margin-top: 12px; padding-top: 12px; border-top: 1px solid #f0f0f0; }
    .menu-group-title { padding: 8px 24px; font-size: 11px; color: #8c8c8c; text-transform: uppercase; letter-spacing: .5px; }
    .main { margin-left: 200px; flex: 1; padding: 24px 28px; }

    /* 页头 */
    .page-head { background: #fff; border-radius: 8px; padding: 18px 24px; margin-bottom: 14px; }
    .page-head h1 { margin: 0 0 4px; font-size: 22px; }
    .page-head .sub { color: #8c8c8c; font-size: 13px; }

    /* KPI 行 */
    .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 14px; }
    .kpi-card { background: #fff; border-radius: 8px; padding: 16px 20px; box-shadow: 0 2px 6px rgba(0,0,0,.04); position: relative; overflow: hidden; }
    .kpi-card::after { content: ""; position: absolute; right: -20px; bottom: -20px; width: 80px; height: 80px; background: var(--kpi-bg, rgba(24,144,255,.06)); border-radius: 50%; }
    .kpi-card.green { --kpi-bg: rgba(82,196,26,.06); }
    .kpi-card.orange { --kpi-bg: rgba(250,140,22,.06); }
    .kpi-card.purple { --kpi-bg: rgba(114,46,209,.06); }
    .kpi-card .kpi-label { font-size: 12px; color: #8c8c8c; display: flex; align-items: center; gap: 6px; }
    .kpi-card .kpi-icon { font-size: 14px; }
    .kpi-card .kpi-value { font-size: 26px; font-weight: 700; color: #262626; margin: 6px 0 4px; line-height: 1.1; position: relative; z-index: 2; }
    .kpi-card .kpi-trend { font-size: 11px; color: #8c8c8c; }
    .kpi-card .kpi-trend .delta-up { color: #389e0d; font-weight: 500; }
    .kpi-card .kpi-trend .delta-down { color: #cf1322; font-weight: 500; }

    /* 待处理小条 */
    .pending-bar { background: #fff; border-radius: 8px; padding: 12px 18px; margin-bottom: 14px; display: flex; gap: 18px; align-items: center; flex-wrap: wrap; }
    .pending-bar .pb-label { font-size: 13px; color: #595959; font-weight: 500; padding-right: 12px; border-right: 1px solid #f0f0f0; }
    .pending-bar .pb-item { display: flex; align-items: center; gap: 6px; font-size: 13px; cursor: pointer; padding: 4px 8px; border-radius: 4px; }
    .pending-bar .pb-item:hover { background: #f0f7ff; }
    .pending-bar .pb-item .pb-num { font-weight: 700; color: #1890ff; font-size: 16px; }
    .pending-bar .pb-item.warn .pb-num { color: #fa8c16; }
    .pending-bar .pb-item.danger .pb-num { color: #cf1322; }
    .pending-bar .pb-item .pb-text { color: #595959; }

    /* 团队预算使用率 */
    .budget-usage-card { background: #fff; border-radius: 8px; padding: 18px 22px; margin-bottom: 14px; }
    .budget-usage-card h3 { margin: 0 0 4px; font-size: 15px; font-weight: 600; }
    .budget-usage-card .bu-sub { color: #8c8c8c; font-size: 12px; margin-bottom: 14px; }
    .budget-row { display: grid; grid-template-columns: 180px 1fr 220px; gap: 14px; align-items: center; padding: 10px 0; border-bottom: 1px dashed #f5f5f5; }
    .budget-row:last-child { border-bottom: none; }
    .bu-name { font-size: 13px; font-weight: 500; }
    .bu-name .bu-tag { font-size: 11px; color: #8c8c8c; font-weight: 400; }
    .bu-bar { height: 14px; background: #f5f5f5; border-radius: 7px; overflow: hidden; display: flex; }
    .bu-segment-spent { background: linear-gradient(90deg, #1890ff, #36cfc9); }
    .bu-segment-locked { background: linear-gradient(90deg, #fa8c16, #ffa940); }
    .bu-stat { font-size: 12px; color: #595959; text-align: right; }
    .bu-stat .bu-stat-val { font-weight: 600; color: #262626; }
    .bu-legend { display: flex; gap: 14px; padding-top: 10px; margin-top: 6px; border-top: 1px solid #f0f0f0; font-size: 12px; color: #8c8c8c; }
    .bu-legend .lg-dot { display: inline-block; width: 10px; height: 10px; border-radius: 2px; margin-right: 4px; vertical-align: middle; }
    .bu-legend .lg-dot.spent { background: #1890ff; }
    .bu-legend .lg-dot.locked { background: #fa8c16; }
    .bu-legend .lg-dot.available { background: #f5f5f5; border: 1px solid #d9d9d9; }

    /* 当前空间账户大卡 */
    .current-card { background: linear-gradient(135deg, #1890ff, #2f54eb); border-radius: 12px; padding: 24px 28px; color: #fff; margin-bottom: 16px; position: relative; overflow: hidden; }
    .current-card.team-budget { background: linear-gradient(135deg, #1890ff, #2f54eb); }
    .current-card.personal { background: linear-gradient(135deg, #fa8c16, #d46b08); }
    .current-card.enterprise-main { background: linear-gradient(135deg, #722ed1, #531dab); }
    .current-card::after { content: ""; position: absolute; right: -40px; top: -40px; width: 220px; height: 220px; background: rgba(255,255,255,.08); border-radius: 50%; }
    .current-card .cc-label { font-size: 12px; opacity: .8; margin-bottom: 4px; position: relative; z-index: 2; }
    .current-card .cc-name { font-size: 18px; font-weight: 500; margin-bottom: 12px; position: relative; z-index: 2; }
    .current-card .cc-balance { font-size: 38px; font-weight: 700; line-height: 1.1; position: relative; z-index: 2; }
    .current-card .cc-meta { display: flex; gap: 28px; margin-top: 16px; padding-top: 14px; border-top: 1px solid rgba(255,255,255,.2); position: relative; z-index: 2; }
    .current-card .cc-meta-item .cc-meta-label { font-size: 11px; opacity: .7; }
    .current-card .cc-meta-item .cc-meta-value { font-size: 16px; font-weight: 600; margin-top: 2px; }
    .current-card .cc-actions { margin-top: 16px; display: flex; gap: 10px; position: relative; z-index: 2; flex-wrap: wrap; }
    .current-card .cc-btn { background: #fff; color: #1890ff; border: none; padding: 8px 18px; border-radius: 6px; font-size: 13px; font-weight: 500; cursor: pointer; }
    .current-card .cc-btn:hover { background: #f0f0f0; }
    .current-card .cc-btn.ghost { background: rgba(255,255,255,.15); color: #fff; }
    .current-card .cc-btn.ghost:hover { background: rgba(255,255,255,.25); }

    .current-card.budget-missing { background: linear-gradient(135deg, #fa541c, #d4380d); }
    .current-card .missing-tip { padding: 10px 14px; background: rgba(255,255,255,.15); border-radius: 6px; font-size: 12px; line-height: 1.6; margin-top: 12px; position: relative; z-index: 2; }

    /* 账户矩阵 */
    .section-head { font-size: 14px; color: #595959; margin: 16px 0 10px; padding: 0 4px; display: flex; align-items: center; gap: 8px; }
    .section-head::before { content: ""; width: 3px; height: 14px; background: #1890ff; border-radius: 2px; }
    .section-head .section-sub { font-weight: 400; color: #8c8c8c; font-size: 12px; }

    .accounts-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 16px; }
    .account-card { background: #fff; border-radius: 8px; padding: 16px 20px; border: 1px solid #f0f0f0; transition: all .2s; }
    .account-card.current { border-color: #1890ff; box-shadow: 0 4px 12px rgba(24,144,255,.12); }
    .account-card .ac-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    .account-card .ac-title { font-size: 14px; font-weight: 500; }
    .account-card .ac-type { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; }
    .account-card .ac-type.personal { background: #fff7e6; color: #d46b08; }
    .account-card .ac-type.team-budget { background: #e6f7ff; color: #096dd9; }
    .account-card .ac-type.enterprise-main { background: #f9f0ff; color: #531dab; }
    .account-card .ac-type.unset { background: #fff1f0; color: #cf1322; }
    .account-card .ac-balance { font-size: 24px; font-weight: 700; color: #262626; margin: 6px 0; }
    .account-card .ac-balance.unset { color: #bfbfbf; font-size: 18px; }
    .account-card .ac-meta { display: flex; justify-content: space-between; padding: 8px 0; font-size: 12px; color: #8c8c8c; border-top: 1px dashed #f0f0f0; margin-top: 6px; }
    .account-card .ac-meta-val { color: #262626; font-weight: 500; }
    .account-card .ac-actions { display: flex; gap: 6px; margin-top: 10px; }
    .account-card .ac-actions button { flex: 1; height: 30px; border: 1px solid #d9d9d9; background: #fff; border-radius: 4px; font-size: 12px; cursor: pointer; }
    .account-card .ac-actions button:hover { border-color: #1890ff; color: #1890ff; }
    .account-card .ac-actions button.primary { background: #1890ff; border-color: #1890ff; color: #fff; }
    .account-card .ac-actions button.primary:hover { background: #40a9ff; border-color: #40a9ff; }
    .account-card .ac-actions button.warn { background: #fa8c16; border-color: #fa8c16; color: #fff; }
    .account-card .ac-actions button.warn:hover { background: #ffa940; border-color: #ffa940; }
    .account-card.limited { background: repeating-linear-gradient(135deg, #fff, #fff 10px, #fafafa 10px, #fafafa 20px); border-style: dashed; }
    .account-card.limited .ac-title { color: #595959; }
    .account-card.limited::before { content: "🔒 受限视图"; position: absolute; top: 12px; right: 14px; font-size: 11px; color: #8c8c8c; background: #fff; padding: 2px 8px; border-radius: 8px; border: 1px solid #f0f0f0; }
    .account-card.limited { position: relative; }

    /* 流水记录 */
    .flow-card { background: #fff; border-radius: 8px; overflow: hidden; }
    .flow-head { padding: 12px 18px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; font-size: 14px; font-weight: 500; }
    .flow-head .flow-filter { display: flex; gap: 8px; }
    .flow-head .flow-filter select { height: 28px; border: 1px solid #d9d9d9; border-radius: 4px; padding: 0 22px 0 8px; font-size: 12px; }
    .flow-row { display: grid; grid-template-columns: 60px 1fr 1.4fr 130px 110px 100px; padding: 12px 18px; align-items: center; border-bottom: 1px solid #f5f5f5; font-size: 13px; }
    .flow-row:last-child { border-bottom: none; }
    .flow-row.head { background: #fafafa; color: #8c8c8c; font-size: 12px; font-weight: 500; }
    .flow-row .flow-icon { font-size: 18px; }
    .flow-row .flow-type-pill { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; }
    .flow-row .flow-type-pill.recharge { background: #f6ffed; color: #389e0d; }
    .flow-row .flow-type-pill.lock { background: #fff7e6; color: #d46b08; }
    .flow-row .flow-type-pill.allocate { background: #e6f7ff; color: #096dd9; }
    .flow-row .flow-type-pill.settle { background: #f9f0ff; color: #531dab; }
    .flow-row .flow-type-pill.refund { background: #fff1f0; color: #cf1322; }
    .flow-row .flow-amt.in { color: #389e0d; font-weight: 600; }
    .flow-row .flow-amt.out { color: #cf1322; font-weight: 600; }
    .flow-row .flow-amt.lock { color: #d46b08; font-weight: 600; }

    /* Modal */
    .modal-mask { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.55); z-index: 999; align-items: center; justify-content: center; padding: 20px; }
    .modal-mask.open { display: flex; }
    .modal { width: 100%; max-width: 520px; background: #fff; border-radius: 12px; box-shadow: 0 12px 36px rgba(0,0,0,.25); overflow: hidden; }
    .modal-head { padding: 16px 22px; background: #fafafa; border-bottom: 1px solid #f0f0f0; }
    .modal-head h3 { margin: 0; font-size: 16px; font-weight: 600; }
    .modal-head p { margin: 4px 0 0; font-size: 12px; color: #8c8c8c; }
    .modal-body { padding: 18px 22px; }
    .modal-foot { padding: 12px 22px; background: #fafafa; border-top: 1px solid #f0f0f0; display: flex; justify-content: flex-end; gap: 8px; }

    .form-field { margin-bottom: 12px; }
    .form-field label { display: block; font-size: 13px; color: #595959; margin-bottom: 6px; }
    .form-field input[type=number], .form-field input[type=text], .form-field select { width: 100%; height: 36px; border: 1px solid #d9d9d9; border-radius: 6px; padding: 0 11px; font-size: 14px; outline: none; }
    .form-field input:focus, .form-field select:focus { border-color: #40a9ff; box-shadow: 0 0 0 2px rgba(24,144,255,.15); }
    .quick-amt { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }
    .quick-amt button { height: 28px; border: 1px solid #d9d9d9; background: #fff; border-radius: 4px; padding: 0 12px; font-size: 12px; cursor: pointer; }
    .quick-amt button:hover { border-color: #1890ff; color: #1890ff; }

    .summary-box { background: #fafafa; border-radius: 6px; padding: 12px; margin: 10px 0; font-size: 13px; }
    .summary-box .sb-row { display: flex; justify-content: space-between; padding: 4px 0; }
    .summary-box .sb-row .sb-label { color: #8c8c8c; }
    .summary-box .sb-row .sb-val { color: #262626; font-weight: 500; }
    .summary-box .sb-arrow { text-align: center; color: #1890ff; padding: 4px 0; font-size: 18px; }

    .info-tip { padding: 10px 12px; background: #e6f7ff; border-left: 3px solid #1890ff; border-radius: 4px; font-size: 12px; color: #096dd9; margin-bottom: 12px; line-height: 1.6; }
    .warn-tip { padding: 10px 12px; background: #fff1f0; border-left: 3px solid #ff4d4f; border-radius: 4px; font-size: 12px; color: #cf1322; margin-bottom: 12px; line-height: 1.6; }

    .btn { height: 36px; border: 1px solid #d9d9d9; background: #fff; border-radius: 6px; padding: 0 18px; font-size: 14px; color: #595959; cursor: pointer; }
    .btn:hover { border-color: #91d5ff; color: #1890ff; }
    .btn.primary { background: #1890ff; border-color: #1890ff; color: #fff; }
    .btn.primary:hover { background: #40a9ff; border-color: #40a9ff; color: #fff; }

    /* Toast */
    .toasts { position: fixed; top: 72px; right: 20px; width: min(90vw, 360px); display: grid; gap: 8px; z-index: 1100; }
    .toast { background: #fff; border: 1px solid #d9d9d9; border-radius: 8px; padding: 10px 14px; font-size: 13px; box-shadow: 0 3px 12px rgba(0,0,0,.1); animation: slideIn .25s ease-out; }
    .toast.ok { border-color: #b7eb8f; background: #f6ffed; color: #389e0d; }
    .toast.err { border-color: #ffccc7; background: #fff2f0; color: #cf1322; }
    .toast.warn { border-color: #ffe58f; background: #fffbe6; color: #d48806; }
    .toast.info { border-color: #91d5ff; background: #e6f7ff; color: #096dd9; }
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

    @media (max-width: 1100px) { .accounts-grid { grid-template-columns: 1fr; } .flow-row { grid-template-columns: 50px 1fr 1fr 100px; } .flow-row > :nth-child(n+5) { display: none; } }
    @media (max-width: 768px) { .sidebar { display: none; } .main { margin-left: 0; padding: 16px; } .ws-trigger { min-width: auto; } .topbar .brand-sub { display: none; } }
  </style>
</head>
<body>
  <header class="topbar">
    <a href="platform-home-demander.html" class="brand">🎬 骋风天合<span class="brand-sub">创作门户交易平台</span></a>
    <div class="ws-switcher">
      <button class="ws-trigger" id="wsTrigger">
        <span id="wsIcon">🏢</span>
        <span class="ws-name" id="wsName">骋风天合 · 短剧制作中心</span>
        <span class="ws-arrow">▼</span>
      </button>
      <div class="ws-dropdown" id="wsDropdown"></div>
    </div>
    <div class="identity-switch" id="identitySwitch">
      <button data-identity="demander" class="active">📥 需求方</button>
      <button data-identity="contractor">🛠 承制方</button>
    </div>
    <a href="wallet-overview.html" class="wallet-chip" id="walletChip">
      <span>💰</span>
      <span>
        <span class="wallet-amount" id="walletAmount">¥185,000</span>
        <span class="wallet-account" id="walletAccount">团队预算账户</span>
      </span>
    </a>
    <div class="avatar-wrap">
      <div class="avatar-trigger" id="avatarTrigger">
        <img src="https://api.dicebear.com/9.x/lorelei/svg?seed=account" alt="头像">
        <span class="avatar-name">昭岚</span>
        <span class="ws-arrow">▼</span>
      </div>
