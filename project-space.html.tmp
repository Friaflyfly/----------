  <!-- Tab 切换 -->
  <script>
  (function () {
    document.querySelectorAll(".tab-item").forEach(el => {
      el.addEventListener("click", () => {
        const target = el.getAttribute("data-tab");
        document.querySelectorAll(".tab-item").forEach(x => x.classList.remove("active"));
        document.querySelectorAll(".tab-pane").forEach(x => x.classList.remove("active"));
        el.classList.add("active");
        document.querySelector('.tab-pane[data-pane="' + target + '"]').classList.add("active");
      });
    });
  })();
  </script>

  <!-- 验收 + 分账 modal -->
  <script>
  (function () {
    const $ = (id) => document.getElementById(id);
    const modal = $("reviewModal");
    let currentStep = 1;
    const orderId = "OD-2026042307";
    const orderAmount = 28000;
    const platformFeeRate = 0.05;
    const platformFee = orderAmount * platformFeeRate;
    const contractorIncome = orderAmount - platformFee;

    // 评分交互
    const ratings = {};
    document.querySelectorAll(".rate-stars").forEach(group => {
      const key = group.getAttribute("data-rate-key");
      ratings[key] = 5; // 默认全 5 星
      group.querySelectorAll(".star").forEach((s, i) => {
        if (i < ratings[key]) s.classList.add("filled");
        s.addEventListener("click", () => {
          ratings[key] = Number(s.getAttribute("data-v"));
          group.querySelectorAll(".star").forEach((x, ii) => x.classList.toggle("filled", ii < ratings[key]));
        });
      });
    });

    function openModal() {
      currentStep = 1;
      showStep(1);
      modal.classList.add("open");
    }
    function closeModal() { modal.classList.remove("open"); }
    function showStep(n) {
      document.querySelectorAll(".review-step").forEach(s => s.classList.remove("active"));
      document.querySelector('.review-step[data-step="' + n + '"]').classList.add("active");
      const foot = $("modalFoot");
      const cancelBtn = $("modalCancelBtn");
      const nextBtn = $("modalNextBtn");
      if (n === 1) {
        cancelBtn.style.display = "";
        nextBtn.style.display = "";
        nextBtn.textContent = "下一步：执行分账 →";
        nextBtn.className = "btn primary large";
      } else if (n === 2) {
        cancelBtn.style.display = "none";
        nextBtn.style.display = "";
        nextBtn.textContent = "完成 ✓";
        nextBtn.className = "btn success large";
        nextBtn.disabled = true;
        // 触发分账动画
        playSettlementAnimation();
      } else if (n === 3) {
        cancelBtn.style.display = "none";
        nextBtn.style.display = "";
        nextBtn.textContent = "查看资金流水 →";
        nextBtn.className = "btn primary large";
        nextBtn.disabled = false;
      }
    }
    function playSettlementAnimation() {
      const source = $("settleSource");
      const arrow = $("settleArrow");
      const contractor = $("settleContractor");
      const platform = $("settlePlatform");
      const note = $("settleNote");
      // 动画序列
      setTimeout(() => arrow.classList.add("show"), 400);
      setTimeout(() => source.classList.add("released"), 900);
      setTimeout(() => contractor.classList.add("show"), 1200);
      setTimeout(() => platform.classList.add("show"), 1500);
      setTimeout(() => { note.style.display = "block"; $("modalNextBtn").disabled = false; }, 2000);
    }

    function executeSettlement() {
      // 真实更新 mock 数据：释放锁定金额、写流水、更新订单状态
      const orders = window.demoApp.getOrders();
      const o = orders.find(x => x.id === orderId);
      if (o) {
        const wallets = window.demoApp.getWallets();
        if (wallets[o.payerWalletKey || "team-budget-cf-drama"]) {
          const w = wallets[o.payerWalletKey || "team-budget-cf-drama"];
          w.lockedAmount = Math.max(0, (w.lockedAmount || 0) - orderAmount);
          window.demoApp.setWallets(wallets);
        }
        window.demoApp.updateOrder(orderId, { status: "completed", completedTime: new Date().toLocaleString("zh-CN") });
        window.demoApp.updateDemand(o.demandId || "DM-2026042103", { status: "completed" });
      }
      const now = new Date();
      const tStr = now.getFullYear() + "-" + String(now.getMonth() + 1).padStart(2, "0") + "-" + String(now.getDate()).padStart(2, "0") + " " + String(now.getHours()).padStart(2, "0") + ":" + String(now.getMinutes()).padStart(2, "0");
      window.demoApp.addFlow({ id: "F-S" + Date.now(), time: tStr, type: "settle", desc: "订单结算分账 - " + orderId + "「新剧 IP 海报系列」", account: "team-budget-cf-drama", amount: -orderAmount, operator: "系统" });
      window.demoApp.addFlow({ id: "F-S" + Date.now() + "c", time: tStr, type: "settle", desc: "承制方实际入账（订单 " + orderId + "）", account: "team-budget-cf-drama", amount: 0, lockedNote: "→ 星辰创作 " + window.fmtMoney(contractorIncome), operator: "系统" });
      window.demoApp.addFlow({ id: "F-S" + Date.now() + "p", time: tStr, type: "settle", desc: "平台服务费 5% - " + orderId, account: "enterprise-main-cf", amount: 0, lockedNote: "→ 平台服务费 " + window.fmtMoney(platformFee), operator: "系统" });
      $("step3Time").textContent = tStr;
    }

    $("modalNextBtn").addEventListener("click", () => {
      if (currentStep === 1) { currentStep = 2; showStep(2); }
      else if (currentStep === 2) { executeSettlement(); currentStep = 3; showStep(3); }
      else if (currentStep === 3) { closeModal(); window.demoToast("已结算 · 即将跳转钱包", "ok"); setTimeout(() => location.href = "wallet-overview.html", 800); }
    });
    $("modalCancelBtn").addEventListener("click", closeModal);

    $("approveVersionBtn").addEventListener("click", openModal);
    $("footerApproveBtn").addEventListener("click", openModal);

    // 驳回 modal
    $("rejectVersionBtn").addEventListener("click", () => $("rejectModal").classList.add("open"));
    $("footerRejectBtn").addEventListener("click", () => $("rejectModal").classList.add("open"));
    $("confirmRejectBtn").addEventListener("click", () => {
      const reason = $("rejectReason").value.trim();
      if (!reason) { window.demoToast("请填写驳回原因", "err"); return; }
      $("rejectModal").classList.remove("open");
      window.demoToast("✅ 已驳回 V3，承制方将收到通知（模拟下版本）", "ok");
    });

    // 沟通发送
    $("sendChatBtn").addEventListener("click", () => {
      const v = $("chatInput").value.trim();
      if (!v) return;
      const area = $("chatArea");
      const div = document.createElement("div");
      div.className = "chat-msg demander";
      div.innerHTML = '<div class="chat-avatar">🌸</div><div><div class="chat-bubble">' + v.replace(/</g, "&lt;") + '</div><div class="chat-meta">昭岚 · 刚刚</div></div>';
      area.appendChild(div);
      $("chatInput").value = "";
      area.scrollTop = area.scrollHeight;
      window.demoToast("已发送（mock）", "info");
    });

    // 版本筛选
    $("versionFilter").addEventListener("change", e => {
      const val = e.target.value;
      document.querySelectorAll(".version-card").forEach(c => {
        if (val === "all") c.style.display = "";
        else if (val === "latest") c.style.display = c.classList.contains("current") ? "" : "none";
        else if (val === "rejected") c.style.display = c.classList.contains("rejected") ? "" : "none";
      });
    });
  })();
  </script>
</body>
</html>
