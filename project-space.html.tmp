<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>项目协同空间 - 骋风天合 · 创作门户交易平台</title>
  <style>
    * { box-sizing: border-box; }
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif; background: #f5f5f5; color: #262626; }

    /* 顶部全局栏 */
    .topbar { position: fixed; top: 0; left: 0; right: 0; height: 56px; background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.06); z-index: 200; display: flex; align-items: center; padding: 0 20px; gap: 16px; }
    .topbar .brand { display: flex; align-items: center; gap: 8px; font-weight: 600; font-size: 16px; color: #1890ff; text-decoration: none; min-width: 220px; }
    .topbar .brand-sub { color: #8c8c8c; font-weight: 400; font-size: 12px; margin-left: 4px; }
    .ws-switcher { position: relative; }
    .ws-trigger { display: flex; align-items: center; gap: 8px; padding: 6px 12px; border: 1px solid #e8e8e8; border-radius: 6px; background: #fafafa; cursor: pointer; font-size: 13px; min-width: 240px; }
    .ws-trigger:hover { border-color: #1890ff; background: #e6f7ff; }
    .ws-trigger .ws-name { font-weight: 500; color: #262626; flex: 1; }
    .ws-trigger .ws-arrow { color: #8c8c8c; font-size: 10px; }
    .ws-dropdown { display: none; position: absolute; top: calc(100% + 6px); left: 0; min-width: 320px; background: #fff; border: 1px solid #e8e8e8; border-radius: 8px; box-shadow: 0 6px 16px rgba(0,0,0,.12); padding: 8px; z-index: 300; }
    .ws-dropdown.open { display: block; }
    .ws-group-label { font-size: 12px; color: #8c8c8c; padding: 6px 10px; }
    .ws-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 6px; cursor: pointer; font-size: 13px; }
    .ws-item:hover { background: #f0f7ff; }
    .ws-item.active { background: #e6f7ff; }
    .ws-item .ws-item-icon { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .ws-item .ws-item-icon.personal { background: #fff7e6; color: #fa8c16; }
    .ws-item .ws-item-icon.team { background: #e6f7ff; color: #1890ff; }
    .ws-item .ws-item-icon.admin { background: #f9f0ff; color: #722ed1; }
    .ws-item .ws-item-main { flex: 1; min-width: 0; }
    .ws-item .ws-item-name { font-weight: 500; color: #262626; }
    .ws-item .ws-item-desc { font-size: 12px; color: #8c8c8c; margin-top: 2px; }
    .ws-item .ws-item-check { color: #1890ff; font-size: 14px; }
    .identity-switch { display: flex; gap: 4px; background: #f0f0f0; border-radius: 18px; padding: 3px; }
    .identity-switch button { border: none; background: transparent; padding: 5px 14px; border-radius: 16px; font-size: 13px; color: #595959; cursor: pointer; }
    .identity-switch button.active { background: #fff; color: #1890ff; box-shadow: 0 1px 2px rgba(0,0,0,.06); font-weight: 500; }
    .wallet-chip { display: flex; align-items: center; gap: 8px; padding: 6px 14px; background: linear-gradient(135deg, #fff7e6, #fff1d6); border: 1px solid #ffd591; border-radius: 18px; cursor: pointer; font-size: 13px; color: #d46b08; text-decoration: none; }
    .wallet-chip:hover { border-color: #fa8c16; }
    .wallet-chip .wallet-amount { font-weight: 600; font-size: 14px; }
    .wallet-chip .wallet-account { font-size: 11px; opacity: .85; }
    .avatar-wrap { position: relative; margin-left: auto; }
    .avatar-trigger { display: flex; align-items: center; gap: 8px; cursor: pointer; padding: 4px 8px; border-radius: 18px; }
    .avatar-trigger:hover { background: #f5f5f5; }
    .avatar-trigger img { width: 32px; height: 32px; border-radius: 50%; border: 1px solid #f0f0f0; }
    .avatar-trigger .avatar-name { font-size: 13px; color: #262626; }
    .avatar-dropdown { display: none; position: absolute; top: calc(100% + 6px); right: 0; min-width: 220px; background: #fff; border: 1px solid #e8e8e8; border-radius: 8px; box-shadow: 0 6px 16px rgba(0,0,0,.12); padding: 8px; z-index: 300; }
    .avatar-dropdown.open { display: block; }
    .avatar-dropdown a { display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 6px; color: #262626; text-decoration: none; font-size: 13px; }
    .avatar-dropdown a:hover { background: #f0f7ff; color: #1890ff; }
    .avatar-dropdown .divider { height: 1px; background: #f0f0f0; margin: 6px 4px; }

    /* 布局 */
    .app { display: flex; padding-top: 56px; min-height: 100vh; }
    .sidebar { width: 200px; background: #fff; box-shadow: 2px 0 8px rgba(0,0,0,.06); position: fixed; top: 56px; left: 0; bottom: 0; padding: 16px 0; overflow-y: auto; }
    .menu a { display: flex; align-items: center; gap: 10px; padding: 11px 24px; color: #262626; text-decoration: none; border-left: 3px solid transparent; font-size: 14px; }
    .menu a:hover { background: #f0f7ff; color: #1890ff; }
    .menu a.active { background: #e6f7ff; color: #1890ff; border-left-color: #1890ff; font-weight: 500; }
    .menu-icon { width: 18px; text-align: center; }
    .menu-group { margin-top: 12px; padding-top: 12px; border-top: 1px solid #f0f0f0; }
    .menu-group-title { padding: 8px 24px; font-size: 11px; color: #8c8c8c; text-transform: uppercase; letter-spacing: .5px; }
    .main { margin-left: 200px; flex: 1; padding: 22px 28px 100px; }

    /* 面包屑 */
    .breadcrumb { font-size: 13px; margin-bottom: 12px; }
    .breadcrumb a { color: #1890ff; text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }
    .breadcrumb span { color: #bfbfbf; margin: 0 6px; }

    /* 订单概览 banner */
    .order-banner { background: linear-gradient(135deg, #1890ff 0%, #2f54eb 100%); border-radius: 12px; padding: 22px 26px; color: #fff; margin-bottom: 14px; position: relative; overflow: hidden; }
    .order-banner::after { content: ""; position: absolute; right: -40px; top: -40px; width: 200px; height: 200px; background: rgba(255,255,255,.08); border-radius: 50%; }
    .order-banner.completed { background: linear-gradient(135deg, #52c41a, #389e0d); }
    .order-banner h1 { margin: 0 0 6px; font-size: 22px; font-weight: 600; position: relative; z-index: 2; }
    .order-banner .ob-id { font-size: 12px; opacity: .85; font-family: monospace; padding: 2px 10px; background: rgba(255,255,255,.15); border-radius: 10px; display: inline-block; margin-right: 8px; }
    .order-banner .ob-cat { font-size: 12px; opacity: .85; }
    .order-banner .ob-meta { display: flex; gap: 28px; margin-top: 14px; flex-wrap: wrap; position: relative; z-index: 2; }
    .order-banner .ob-meta-item .ob-meta-label { font-size: 11px; opacity: .75; }
    .order-banner .ob-meta-item .ob-meta-val { font-size: 14px; font-weight: 500; margin-top: 2px; }

    /* 进度条 */
    .progress-bar { background: #fff; border-radius: 8px; padding: 18px 24px; margin-bottom: 14px; }
    .progress-steps { display: grid; grid-template-columns: repeat(5, 1fr); position: relative; }
    .progress-step { display: flex; flex-direction: column; align-items: center; position: relative; }
    .progress-step:not(:last-child)::after { content: ""; position: absolute; top: 14px; right: -50%; width: 100%; height: 2px; background: #f0f0f0; z-index: 0; }
    .progress-step.done:not(:last-child)::after { background: #52c41a; }
    .progress-step.current:not(:last-child)::after { background: linear-gradient(90deg, #52c41a 50%, #f0f0f0 50%); }
    .progress-step .ps-icon { width: 30px; height: 30px; border-radius: 50%; background: #f0f0f0; color: #8c8c8c; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; z-index: 1; position: relative; }
    .progress-step.done .ps-icon { background: #52c41a; color: #fff; }
    .progress-step.current .ps-icon { background: #1890ff; color: #fff; box-shadow: 0 0 0 4px rgba(24,144,255,.18); }
    .progress-step .ps-name { font-size: 12px; color: #8c8c8c; margin-top: 6px; text-align: center; }
    .progress-step.done .ps-name { color: #389e0d; }
    .progress-step.current .ps-name { color: #1890ff; font-weight: 500; }
    .progress-step .ps-time { font-size: 10px; color: #bfbfbf; margin-top: 2px; }

    /* 关键指标小条 */
    .key-info { background: #fff; border-radius: 8px; padding: 14px 22px; margin-bottom: 14px; display: flex; gap: 24px; flex-wrap: wrap; align-items: center; }
    .key-info .ki-item { font-size: 12px; }
    .key-info .ki-label { color: #8c8c8c; }
    .key-info .ki-val { color: #262626; font-weight: 500; margin-left: 6px; }
    .key-info .ki-val.urgent { color: #cf1322; }
    .key-info .ki-val.warn { color: #d46b08; }
    .key-info .ki-val.amount { color: #1890ff; font-weight: 600; font-size: 14px; }
    .key-info .ki-divider { width: 1px; height: 16px; background: #f0f0f0; }

    /* Tab */
    .tab-bar { background: #fff; border-radius: 8px 8px 0 0; padding: 0 22px; display: flex; gap: 0; border-bottom: 1px solid #f0f0f0; }
    .tab-item { padding: 14px 18px; cursor: pointer; font-size: 14px; color: #595959; border-bottom: 2px solid transparent; transition: all .15s; }
    .tab-item:hover { color: #1890ff; }
    .tab-item.active { color: #1890ff; border-bottom-color: #1890ff; font-weight: 500; }
    .tab-item .tab-badge { display: inline-block; background: #ff4d4f; color: #fff; font-size: 11px; padding: 1px 6px; border-radius: 8px; margin-left: 4px; font-weight: 400; }

    .tab-content { background: #fff; border-radius: 0 0 8px 8px; padding: 20px 24px; min-height: 400px; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }

    /* === 需求详情 tab === */
    .demand-section { margin-bottom: 18px; }
    .demand-section h3 { margin: 0 0 8px; font-size: 14px; color: #595959; font-weight: 500; }
    .demand-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 24px; padding: 14px 18px; background: #fafafa; border-radius: 6px; }
    .demand-grid .dg-item { font-size: 13px; }
    .demand-grid .dg-label { color: #8c8c8c; font-size: 12px; margin-bottom: 2px; }
    .demand-grid .dg-val { color: #262626; font-weight: 500; }
    .demand-tags { display: flex; gap: 6px; flex-wrap: wrap; }
    .demand-tag { padding: 2px 10px; background: #e6f7ff; color: #096dd9; border-radius: 10px; font-size: 11px; }
    .demand-desc { padding: 12px 14px; background: #fafafa; border-radius: 6px; font-size: 13px; line-height: 1.7; color: #595959; white-space: pre-wrap; }

    /* === 素材包 tab === */
    .file-list .file-item { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border: 1px solid #f0f0f0; border-radius: 6px; margin-bottom: 8px; transition: all .15s; }
    .file-list .file-item:hover { border-color: #91d5ff; background: #fafafa; }
    .file-icon { width: 38px; height: 38px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .file-icon.img { background: linear-gradient(135deg, #ffd6e7, #ffadd2); }
    .file-icon.psd { background: linear-gradient(135deg, #d3adf7, #b37feb); color: #fff; font-weight: 600; font-size: 12px; }
    .file-icon.doc { background: linear-gradient(135deg, #b7eb8f, #95de64); }
    .file-icon.video { background: linear-gradient(135deg, #ffe7ba, #ffd591); }
    .file-icon.zip { background: linear-gradient(135deg, #87e8de, #5cdbd3); }
    .file-info { flex: 1; }
    .file-name { font-size: 14px; font-weight: 500; }
    .file-meta { font-size: 12px; color: #8c8c8c; margin-top: 2px; }
    .file-actions button { height: 28px; padding: 0 12px; border: 1px solid #d9d9d9; background: #fff; border-radius: 4px; font-size: 12px; cursor: pointer; margin-left: 4px; }
    .file-actions button:hover { border-color: #1890ff; color: #1890ff; }

    /* === 交付与版本 tab === */
    .version-timeline { position: relative; padding-left: 32px; }
    .version-timeline::before { content: ""; position: absolute; left: 12px; top: 12px; bottom: 12px; width: 2px; background: #f0f0f0; }
    .version-card { background: #fff; border: 1px solid #f0f0f0; border-radius: 10px; padding: 16px 18px; margin-bottom: 14px; position: relative; }
    .version-card::before { content: ""; position: absolute; left: -27px; top: 22px; width: 14px; height: 14px; border-radius: 50%; background: #d9d9d9; border: 3px solid #fff; box-shadow: 0 0 0 2px #d9d9d9; }
    .version-card.approved::before { background: #52c41a; box-shadow: 0 0 0 2px #52c41a; }
    .version-card.rejected::before { background: #ff4d4f; box-shadow: 0 0 0 2px #ff4d4f; }
    .version-card.current::before { background: #1890ff; box-shadow: 0 0 0 2px #1890ff; animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%, 100% { box-shadow: 0 0 0 2px #1890ff; } 50% { box-shadow: 0 0 0 6px rgba(24,144,255,.3); } }
    .version-card.current { border-color: #1890ff; background: linear-gradient(180deg, #fff, #f0f7ff); }
    .version-head { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; flex-wrap: wrap; }
    .version-tag { padding: 3px 10px; border-radius: 4px; font-size: 12px; font-weight: 600; }
    .version-tag.v1 { background: #f9f0ff; color: #531dab; }
    .version-tag.v2 { background: #fff7e6; color: #d46b08; }
    .version-tag.v3 { background: #e6f7ff; color: #096dd9; }
    .version-tag.v4 { background: #f6ffed; color: #389e0d; }
    .version-status { font-size: 11px; padding: 2px 8px; border-radius: 8px; }
    .version-status.approved { background: #f6ffed; color: #389e0d; }
    .version-status.rejected { background: #fff1f0; color: #cf1322; }
    .version-status.pending { background: #e6f7ff; color: #1890ff; font-weight: 500; }
    .version-time { font-size: 12px; color: #8c8c8c; }
    .version-uploader { font-size: 12px; color: #8c8c8c; }
    .version-files { display: flex; gap: 6px; flex-wrap: wrap; margin: 8px 0; }
    .version-file-pill { padding: 4px 10px; background: #fafafa; border: 1px solid #f0f0f0; border-radius: 4px; font-size: 12px; color: #595959; cursor: pointer; }
    .version-file-pill:hover { border-color: #1890ff; color: #1890ff; }
    .version-note { font-size: 13px; color: #595959; padding: 10px 14px; background: #fafafa; border-radius: 6px; margin-top: 8px; }
    .version-note.reject { background: #fff1f0; color: #cf1322; border-left: 3px solid #ff4d4f; }
    .version-note .vn-title { font-weight: 500; margin-bottom: 4px; font-size: 12px; color: #8c8c8c; }
    .version-note ul { margin: 4px 0 0; padding-left: 20px; }
    .version-preview { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 10px; }
    .version-preview-item { aspect-ratio: 16/10; border-radius: 6px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 500; padding: 8px; text-align: center; }
    .version-actions { display: flex; gap: 8px; margin-top: 12px; padding-top: 12px; border-top: 1px dashed #f0f0f0; }

    /* === 沟通 tab === */
    .chat-area { display: flex; flex-direction: column; gap: 12px; }
    .chat-msg { display: flex; gap: 10px; max-width: 70%; }
    .chat-msg.demander { align-self: flex-start; }
    .chat-msg.contractor { align-self: flex-end; flex-direction: row-reverse; }
    .chat-msg.system { align-self: center; max-width: 80%; }
    .chat-avatar { width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 14px; }
    .chat-avatar.contractor { background: linear-gradient(135deg, #ffd6e7, #ffadd2); }
    .chat-bubble { padding: 9px 14px; border-radius: 10px; font-size: 13px; line-height: 1.6; }
    .chat-msg.demander .chat-bubble { background: #f0f0f0; }
    .chat-msg.contractor .chat-bubble { background: #1890ff; color: #fff; }
    .chat-msg.system .chat-bubble { background: #fff7e6; color: #d46b08; font-size: 12px; padding: 6px 12px; border-radius: 12px; }
    .chat-meta { font-size: 11px; color: #8c8c8c; margin-top: 4px; }
    .chat-msg.contractor .chat-meta { text-align: right; }
    .chat-input-row { margin-top: 16px; padding-top: 14px; border-top: 1px solid #f0f0f0; display: flex; gap: 8px; }
    .chat-input-row textarea { flex: 1; height: 60px; padding: 8px 12px; border: 1px solid #d9d9d9; border-radius: 6px; resize: none; font-family: inherit; font-size: 13px; outline: none; }
    .chat-input-row textarea:focus { border-color: #40a9ff; }

    /* === 验收记录 tab === */
    .review-history-card { background: #fafafa; border-radius: 8px; padding: 14px 18px; margin-bottom: 10px; border-left: 3px solid #ffa940; }
    .review-history-card.approved { border-left-color: #52c41a; }
    .review-history-card .rh-head { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; flex-wrap: wrap; }
    .review-history-card .rh-action { font-size: 13px; font-weight: 500; }
    .review-history-card .rh-action.approved { color: #389e0d; }
    .review-history-card .rh-action.rejected { color: #cf1322; }
    .review-history-card .rh-time { font-size: 12px; color: #8c8c8c; }
    .review-history-card .rh-reason { font-size: 13px; color: #595959; line-height: 1.6; }
    .review-history-card .rh-changes { margin-top: 8px; padding: 8px 12px; background: #fff; border-radius: 4px; font-size: 12px; }
    .review-history-card .rh-changes ul { margin: 4px 0 0; padding-left: 18px; color: #595959; }

    /* 底部固定操作条 */
    .footer-bar { position: fixed; bottom: 0; left: 200px; right: 0; background: #fff; border-top: 1px solid #f0f0f0; padding: 14px 28px; display: flex; gap: 10px; align-items: center; z-index: 100; }
    .footer-bar .fb-info { font-size: 13px; color: #595959; margin-right: auto; }
    .footer-bar .fb-info strong { color: #1890ff; }
    .btn { height: 36px; border: 1px solid #d9d9d9; background: #fff; border-radius: 6px; padding: 0 18px; font-size: 14px; color: #595959; cursor: pointer; }
    .btn:hover { border-color: #91d5ff; color: #1890ff; }
    .btn.primary { background: #1890ff; border-color: #1890ff; color: #fff; font-weight: 500; }
    .btn.primary:hover { background: #40a9ff; border-color: #40a9ff; color: #fff; }
    .btn.success { background: #52c41a; border-color: #52c41a; color: #fff; font-weight: 500; }
    .btn.success:hover { background: #73d13d; border-color: #73d13d; }
    .btn.danger { color: #cf1322; border-color: #ffccc7; }
    .btn.danger:hover { color: #ff4d4f; border-color: #ff4d4f; background: #fff1f0; }
    .btn.large { height: 40px; padding: 0 24px; }
    .btn:disabled { color: #bfbfbf; border-color: #f0f0f0; background: #fafafa; cursor: not-allowed; }

    /* === 验收 + 分账 modal === */
    .modal-mask { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.55); z-index: 999; align-items: center; justify-content: center; padding: 20px; }
    .modal-mask.open { display: flex; }
    .modal-large { width: 100%; max-width: 720px; max-height: 92vh; background: #fff; border-radius: 12px; box-shadow: 0 12px 36px rgba(0,0,0,.25); overflow: hidden; display: flex; flex-direction: column; }
    .modal-large .ml-head { padding: 18px 24px; background: linear-gradient(135deg, #52c41a, #389e0d); color: #fff; }
    .modal-large .ml-head h3 { margin: 0; font-size: 18px; }
    .modal-large .ml-head p { margin: 4px 0 0; font-size: 12px; opacity: .9; }
    .modal-large .ml-body { padding: 22px 26px; overflow-y: auto; flex: 1; }
    .modal-large .ml-foot { padding: 14px 26px; background: #fafafa; border-top: 1px solid #f0f0f0; display: flex; justify-content: flex-end; gap: 10px; }

    .review-step { display: none; }
    .review-step.active { display: block; }
    .review-step h4 { margin: 0 0 12px; font-size: 15px; }

    /* 步骤 1：评分反馈 */
    .rate-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px dashed #f0f0f0; }
    .rate-row:last-child { border-bottom: none; }
    .rate-label { font-size: 13px; color: #595959; }
    .rate-stars { display: flex; gap: 4px; }
    .rate-stars .star { font-size: 22px; color: #f0f0f0; cursor: pointer; transition: color .15s; }
    .rate-stars .star.filled { color: #fa8c16; }
    .rate-stars .star:hover { color: #ffa940; }
    .feedback-textarea { width: 100%; min-height: 80px; border: 1px solid #d9d9d9; border-radius: 6px; padding: 10px; font-family: inherit; font-size: 13px; resize: vertical; outline: none; margin-top: 8px; }

    /* 步骤 2：分账动画 */
    .settle-animation { padding: 20px 0; }
    .settle-source { background: linear-gradient(135deg, #fff7e6, #fff1d6); border: 2px solid #ffd591; border-radius: 12px; padding: 20px; text-align: center; margin-bottom: 0; transition: all .6s; }
    .settle-source .ss-label { font-size: 12px; color: #d46b08; }
    .settle-source .ss-amount { font-size: 36px; font-weight: 700; color: #d46b08; margin-top: 4px; }
    .settle-source .ss-account { font-size: 12px; color: #d46b08; margin-top: 4px; opacity: .8; }
    .settle-source.released { opacity: .4; transform: scale(.95); }

    .settle-arrow { text-align: center; padding: 14px 0; color: #1890ff; font-size: 28px; transition: opacity .4s; opacity: 0; }
    .settle-arrow.show { opacity: 1; }

    .settle-targets { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .settle-target { border: 2px solid #f0f0f0; border-radius: 12px; padding: 16px 18px; opacity: 0; transform: translateY(20px); transition: all .5s; }
    .settle-target.show { opacity: 1; transform: translateY(0); }
    .settle-target.contractor { border-color: #b7eb8f; background: linear-gradient(135deg, #f6ffed, #d9f7be); }
    .settle-target.platform { border-color: #91d5ff; background: linear-gradient(135deg, #e6f7ff, #bae7ff); }
    .settle-target .st-label { font-size: 11px; color: #8c8c8c; margin-bottom: 4px; }
    .settle-target.contractor .st-label { color: #389e0d; }
    .settle-target.platform .st-label { color: #096dd9; }
    .settle-target .st-name { font-size: 13px; font-weight: 500; color: #262626; margin-bottom: 6px; }
    .settle-target .st-amount { font-size: 22px; font-weight: 700; }
    .settle-target.contractor .st-amount { color: #389e0d; }
    .settle-target.platform .st-amount { color: #096dd9; }
    .settle-target .st-pct { font-size: 11px; color: #8c8c8c; margin-top: 2px; }
    .settle-target .st-detail { font-size: 11px; color: #8c8c8c; margin-top: 8px; padding-top: 8px; border-top: 1px dashed rgba(0,0,0,.06); line-height: 1.6; }

    /* 步骤 3：完成 */
    .step3-success { text-align: center; padding: 30px 20px; }
    .step3-icon { font-size: 64px; margin-bottom: 12px; }
    .step3-title { font-size: 22px; font-weight: 700; color: #389e0d; margin-bottom: 8px; }
    .step3-desc { font-size: 13px; color: #595959; margin-bottom: 18px; }
    .step3-summary { background: #f6ffed; border-radius: 8px; padding: 14px 18px; max-width: 460px; margin: 0 auto; text-align: left; font-size: 13px; line-height: 2; }
    .step3-summary .ss-row { display: flex; justify-content: space-between; }
    .step3-summary .ss-row .ss-label { color: #8c8c8c; }
    .step3-summary .ss-row .ss-val { color: #262626; font-weight: 500; }

    /* Toast */
    .toasts { position: fixed; top: 72px; right: 20px; width: min(90vw, 360px); display: grid; gap: 8px; z-index: 1100; }
    .toast { background: #fff; border: 1px solid #d9d9d9; border-radius: 8px; padding: 10px 14px; font-size: 13px; box-shadow: 0 3px 12px rgba(0,0,0,.1); animation: slideIn .25s ease-out; }
    .toast.ok { border-color: #b7eb8f; background: #f6ffed; color: #389e0d; }
    .toast.err { border-color: #ffccc7; background: #fff2f0; color: #cf1322; }
    .toast.warn { border-color: #ffe58f; background: #fffbe6; color: #d48806; }
    .toast.info { border-color: #91d5ff; background: #e6f7ff; color: #096dd9; }
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

    @media (max-width: 1100px) {
      .progress-steps { grid-template-columns: repeat(5, 1fr); font-size: 11px; }
      .demand-grid { grid-template-columns: 1fr; }
      .settle-targets { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .sidebar { display: none; }
      .main { margin-left: 0; padding: 16px 16px 100px; }
      .footer-bar { left: 0; }
    }
  </style>
</head>
