                <span class="version-file-pill" onclick="window.demoToast('演示环境，预览未接通', 'info')">🖼 衍生_朱雀.png · 6.1 MB</span>
                <span class="version-file-pill" onclick="window.demoToast('演示环境，预览未接通', 'info')">🖼 衍生_玄武.png · 6.4 MB</span>
              </div>
              <div class="version-preview">
                <div class="version-preview-item" style="background:linear-gradient(135deg,#722ed1,#13c2c2)">主视觉 V3 · 主角玉冠束发</div>
                <div class="version-preview-item" style="background:linear-gradient(135deg,#f5222d,#fa541c)">封面 V3 · 龙腾云海</div>
