              <div class="dg-item"><div class="dg-label">期望交付</div><div class="dg-val">2026-04-30</div></div>
              <div class="dg-item"><div class="dg-label">承制方报价交期</div><div class="dg-val">14 天（4 月 23 日 - 5 月 7 日，含 3 轮修改）</div></div>
            </div>
