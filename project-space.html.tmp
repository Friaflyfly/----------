      <div class="tab-content">
        <!-- 需求详情 -->
        <div class="tab-pane" data-pane="demand">
          <div class="demand-section">
            <h3>基本信息</h3>
            <div class="demand-grid">
              <div class="dg-item"><div class="dg-label">服务类目</div><div class="dg-val">图片设计 / 海报设计</div></div>
              <div class="dg-item"><div class="dg-label">服务等级 / 制作方式</div><div class="dg-val">高品质 / 重点 CG 特效</div></div>
